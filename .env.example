# Solar Tax Engine — Environment Variables
# Copy to .env.local and fill in values

# ─── Database (Turso) ────────────────────────────────────────────────────────
# Get from: https://turso.tech → your database → Connect
DATABASE_URL="libsql://YOUR-DB-NAME.turso.io"
TURSO_AUTH_TOKEN="your-turso-auth-token"

# For local SQLite dev (no Turso account needed):
# DATABASE_URL="file:./dev.db"
# Comment out TURSO_AUTH_TOKEN for local

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── AI Layer (Phase 2 — placeholder, not active in MVP) ─────────────────────
# OPENAI_API_KEY=""
# WHISPER_MODEL="whisper-1"
